# Chatwoot Configuration
CHATWOOT_API_URL=https://your-chatwoot-domain.com/api/v1
CHATWOOT_API_TOKEN=your_chatwoot_api_token_here
CHATWOOT_WEBHOOK_SECRET=your_webhook_signing_key_here

# Botpress Configuration
BOTPRESS_BOT_ID=your_botpress_bot_id
BOTPRESS_API_TOKEN=your_botpress_api_token
BOTPRESS_API_URL=https://api.botpress.cloud/v1

# Server Configuration
PORT=3001
NODE_ENV=production
